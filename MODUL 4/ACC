════════════╣");
System.out.printf ("║ Nama : %-27s ║%n", nama);

System.out.printf ("║ Jabatan : %-27s ║%n", jabatan);
System.out.printf ("║ Status : %-27s ║%n", "Karyawan Tetap");
System.out.println("╠══════════════════════════════════
════════════╣");
System.out.printf ("║ Hadir : %-4d hari ║%n",
jumlahHadir);
System.out.printf ("║ Lembur : %-4d jam ║%n",
jamLembur);
System.out.println("╠══════════════════════════════════
════════════╣");
System.out.printf ("║ Gaji Pokok : Rp %,-18.0f ║%n", gajiPokok);
System.out.printf ("║ Uang Lembur : Rp %,-18.0f ║%n", uangLembur);
System.out.printf ("║ Bonus : Rp %,-18.0f ║%n", bonus);
System.out.println("╠══════════════════════════════════
════════════╣");
System.out.printf ("║ TOTAL GAJI : Rp %,-18.0f ║%n", totalGaji);
System.out.printf ("║ Jadwal Gaji : %-27s ║%n", "Hari " + jadwalGaji());
System.out.println("╚══════════════════════════════════
════════════╝");
}
}

