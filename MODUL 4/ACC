// Method untuk memvalidasi input integer agar tidak crash
private static int inputInteger(Scanner sc, String prompt) {
int nilai = 0;
boolean valid = false;
while (!valid) {
System.out.print(prompt);
try {
nilai = Integer.parseInt(sc.nextLine().trim()); // Baca dan parse input
if (nilai < 0) {
System.out.println(" [!] Nilai tidak boleh negatif. Coba lagi.");
} else {
valid = true; // Input valid, keluar dari loop
}
} catch (NumberFormatException e) {
System.out.println(" [!] Input harus berupa angka. Coba lagi.");
}
}
return nilai;
}

