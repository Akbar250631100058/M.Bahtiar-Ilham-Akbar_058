//
==========================================================
==
// INTERFACE: Mendefinisikan kontrak perhitungan gaji
// Setiap kelas yang mengimplementasi interface ini WAJIB
// mengimplementasikan semua method yang ada di dalamnya.
//
==========================================================
==
interface Penggajian {

// Method untuk menghitung total gaji karyawan
double hitungGaji();

// Method untuk menentukan hari pembagian gaji
String jadwalGaji();

// Method untuk menampilkan laporan lengkap karyawan
void tampilkanLaporan();
}

//
==========================================================
==
// ABSTRACT CLASS: Kelas dasar untuk semua jenis karyawan
// Abstract class tidak bisa diinstansiasi langsung,
// harus diwariskan ke subclass terlebih dahulu.

//
==========================================================
==
abstract class Karyawan implements Penggajian {

// Atribut dasar yang dimiliki semua karyawan
protected String nama; // Nama karyawan
protected String jabatan; // Jabatan karyawan
protected int jumlahHadir; // Total hari hadir

// Konstanta gaji per hari (final = tidak bisa diubah)
protected final double GAJI_PER_HARI = 120_000; // Rp 120.000/hari
protected final double GAJI_LEMBUR = 45_000; // Rp 45.000/jam lembur
protected final double BONUS_TINGGI = 750_000; // Bonus jika hadir >=
26 hari
protected final double BONUS_SEDANG = 450_000; // Bonus jika hadir >=
20 hari

// Konstruktor untuk menginisialisasi data dasar karyawan
public Karyawan(String nama, String jabatan, int jumlahHadir) {
this.nama = nama;
this.jabatan = jabatan;
this.jumlahHadir = jumlahHadir;
}

// Method untuk menghitung bonus berdasarkan jumlah kehadiran
protected double hitungBonus() {
if (jumlahHadir >= 26) {
return BONUS_TINGGI; // Bonus Rp 750.000 jika hadir >= 26 hari

} else if (jumlahHadir >= 20) {
return BONUS_SEDANG; // Bonus Rp 450.000 jika hadir >= 20 hari
} else {
return 0; // Tidak dapat bonus jika hadir < 20 hari
}
}

// Abstract method: WAJIB diimplementasikan oleh subclass
// Setiap jenis karyawan punya cara hitung lembur masing-masing
@Override
public abstract double hitungGaji();

// Method untuk menentukan jadwal gaji berdasarkan total gaji
@Override
public String jadwalGaji() {
double gaji = hitungGaji(); // Ambil total gaji terlebih dahulu

// Penentuan hari gaji berdasarkan range nominal gaji
if (gaji < 1_000_000) {
return "Senin"; // Gaji < 1 juta
} else if (gaji <= 2_500_000) {
return "Selasa"; // Gaji 1 juta s/d 2,5 juta
} else if (gaji <= 3_500_000) {
return "Rabu"; // Gaji 2,5 juta s/d 3,5 juta
} else if (gaji <= 4_500_000) {
return "Kamis"; // Gaji 3,5 juta s/d 4,5 juta
} else if (gaji <= 5_500_000) {

return "Jumat"; // Gaji 4,5 juta s/d 5,5 juta
} else {
return "Sabtu"; // Gaji > 5,5 juta
}
}

// Getter untuk mengakses atribut dari luar kelas
public String getNama() { return nama; }
public String getJabatan() { return jabatan; }
public int getJumlahHadir() { return jumlahHadir; }
}

//
==========================================================
==
// SUBCLASS: KaryawanTetap
// Mewarisi Karyawan, memiliki jam lembur tetap per bulan
//
==========================================================
==
class KaryawanTetap extends Karyawan {

private int jamLembur; // Jumlah jam lembur dalam sebulan

// Konstruktor KaryawanTetap
public KaryawanTetap(String nama, String jabatan, int jumlahHadir, int
jamLembur) {
super(nama, jabatan, jumlahHadir); // Memanggil konstruktor parent
this.jamLembur = jamLembur;

}

// Implementasi wajib dari abstract method hitungGaji()
// Rumus: (hadir x 120.000) + (jam lembur x 45.000) + bonus
@Override
public double hitungGaji() {
double gajiPokok = jumlahHadir * GAJI_PER_HARI; // Gaji pokok harian
double uangLembur = jamLembur * GAJI_LEMBUR; // Upah lembur
double bonus = hitungBonus(); // Bonus kehadiran
return gajiPokok + uangLembur + bonus; // Total gaji
}

// Implementasi method tampilkanLaporan dari interface Penggajian
@Override
public void tampilkanLaporan() {
double gajiPokok = jumlahHadir * GAJI_PER_HARI;
double uangLembur = jamLembur * GAJI_LEMBUR;
double bonus = hitungBonus();
double totalGaji = hitungGaji();

System.out.println("\n╔═════════════════════════════════
═════════════╗");
