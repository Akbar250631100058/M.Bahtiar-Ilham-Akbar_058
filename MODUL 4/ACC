// SUBCLASS: KaryawanKontrak
// Mewarisi Karyawan, tidak mendapat bonus kehadiran penuh
// namun tetap ada bonus minimal sebagai insentif kontrak

//
==========================================================
==
class KaryawanKontrak extends Karyawan {

private final int jamLembur; // Jumlah jam lembur
private final String periodeKontrak; // Masa kontrak (contoh: "6 bulan")

// Konstruktor KaryawanKontrak
