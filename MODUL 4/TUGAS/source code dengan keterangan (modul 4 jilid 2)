import java.util.Scanner; // Mengimpor class Scanner untuk input keyboard

// Interface Phone
interface Phone {

    // Konstanta volume maksimum dan minimum
    int MAX_VOLUME = 100;
    int MIN_VOLUME = 0;

    // Method yang harus diimplementasikan oleh class turunan
    void powerOn();
    void powerOff();
    void volumeUp();
    void volumeDown();
}

// Class pengguna HP
class PhoneUser {

    // Variabel bertipe interface Phone
    private Phone phone;

    // Constructor
    public PhoneUser(Phone phone) {
        this.phone = phone;
    }

    // Method menyalakan HP
    void turnOnThePhone() {
        this.phone.powerOn();
    }

    // Method mematikan HP
    void turnOffThePhone() {
        this.phone.powerOff();
    }

    // Method menambah volume
    void makePhoneLouder() {
        this.phone.volumeUp();
    }

    // Method mengurangi volume
    void makePhoneSilent() {
        this.phone.volumeDown();
    }
}

// Class Samsung mengimplementasikan interface Phone
class Samsung implements Phone {

    // Variabel volume
    private int volume;

    // Status HP hidup atau mati
    private boolean isPowerOn;

    // Constructor
    public Samsung() {
        this.volume = 50; // volume awal
    }

    // Method menyalakan HP
    public void powerOn() {
        isPowerOn = true;
        System.out.println("Handphone menyala...");
        System.out.println("Selamat datang di SAMSUNG");
        System.out.println("Android Version 14");
    }

    // Method mematikan HP
    public void powerOff() {
        isPowerOn = false;
        System.out.println("Handphone dimatikan");
    }

    // Method memperbesar volume
    public void volumeUp() {

        if (isPowerOn) {

            if (this.volume == MAX_VOLUME) {

                System.out.println("Volume FULL!!");
                System.out.println("Sudah " + this.getVolume() + "%");

            } else {

                this.volume += 10;
                System.out.println("Volume sekarang : " + this.getVolume());
            }

        } else {

            System.out.println("Nyalakan dulu HP-nya!");
        }
    }

    // Method memperkecil volume
    public void volumeDown() {

        if (isPowerOn) {

            if (this.volume == MIN_VOLUME) {

                System.out.println("Volume = 0%");

            } else {

                this.volume -= 10;
                System.out.println("Volume sekarang : " + this.getVolume());
            }

        } else {

            System.out.println("Nyalakan dulu HP-nya!");
        }
    }

    // Method mengambil nilai volume
    public int getVolume() {
        return this.volume;
    }
}

// Class utama
public class Main {

    public static void main(String[] args) {

        // Membuat objek Samsung
        Phone galaxyA55 = new Samsung();

        // Membuat objek pengguna HP
        PhoneUser laili = new PhoneUser(galaxyA55);

        // Menyalakan HP saat program dimulai
        laili.turnOnThePhone();

        // Membuat Scanner
        Scanner input = new Scanner(System.in);

        String aksi;

        while (true) {

            System.out.println("\n=== APLIKASI INTERFACE ===");
            System.out.println("[1] Nyalakan HP");
            System.out.println("[2] Matikan HP");
            System.out.println("[3] Perbesar Volume");
            System.out.println("[4] Kecilkan Volume");
            System.out.println("[0] Keluar");
            System.out.print("Pilih aksi > ");

            aksi = input.nextLine();

            if (aksi.equals("1")) {

                laili.turnOnThePhone();

            } else if (aksi.equals("2")) {

                laili.turnOffThePhone();

            } else if (aksi.equals("3")) {

                laili.makePhoneLouder();

            } else if (aksi.equals("4")) {

                laili.makePhoneSilent();

            } else if (aksi.equals("0")) {

                System.out.println("Program selesai");
                break;

            } else {

                System.out.println("Pilihan tidak tersedia!");
            }
        }

        input.close();
    }
}
